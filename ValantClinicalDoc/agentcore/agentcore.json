{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "ValantClinicalDoc",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "ValantClinicalDoc"
  },
  "runtimes": [
    {
      "name": "ClinicalDocAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/ClinicalDocAgent/",
      "runtimeVersion": "PYTHON_3_12",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "idleTimeout": 900,
      "maxLifetime": 3600
    }
  ],
  "memories": [
    {
      "name": "ClinicalDocMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "USER_PREFERENCE",
          "namespaces": [
            "/users/{actorId}/preferences"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "harnesses": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": []
}